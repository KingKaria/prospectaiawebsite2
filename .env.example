# Variáveis de ambiente do formulário de contacto (Resend).
# Apenas variáveis de servidor — NUNCA prefixar com NEXT_PUBLIC_.
# Estes são valores ILUSTRATIVOS e não funcionais. Copie este ficheiro
# para .env.local e substitua pelos valores reais (o .env.local nunca é
# versionado). Em produção, defina-as no painel do fornecedor de
# alojamento (ex. Vercel) como variáveis de servidor.

# Chave de API do Resend (secreta — só no servidor).
RESEND_API_KEY=re_example_only

# Remetente verificado no Resend, no formato "Nome <email>".
# Usa um subdomínio dedicado ao envio (ex. mail.prospectaia.pt), separado
# do domínio principal — isola a reputação de envio e evita conflitos com
# os registos MX/SPF da caixa de correio normal (contacto@prospectaia.pt).
CONTACT_EMAIL_FROM=ProspectAIA <contacto@mail.prospectaia.pt>

# Destinatário fixo das mensagens do formulário — o endereço público de
# receção, no domínio principal (não no subdomínio de envio).
CONTACT_EMAIL_TO=contacto@prospectaia.pt

# Rate limiting persistente do formulário de contacto (Upstash Redis).

# Endpoint REST e token do Upstash Redis (secreto — só no servidor).
UPSTASH_REDIS_REST_URL=https://example-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=upstash_example_token_only

# Segredo usado para derivar (via HMAC-SHA-256) um identificador
# pseudónimo a partir do IP do remetente. Nunca o mesmo valor de
# RESEND_API_KEY nem de nenhum outro segredo. Gere um valor aleatório
# longo (ex. `openssl rand -hex 32`) ao configurar o ambiente real.
CONTACT_RATE_LIMIT_SECRET=example_only_generate_a_real_random_secret
